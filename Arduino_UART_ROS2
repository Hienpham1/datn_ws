#include <Encoder.h>
#include <Wire.h> // Thư viện I2C cho IMU

// ========== KHAI BÁO CHÂN TỐI ƯU ========== //
// Motor 1 (Dùng Timer0 - An toàn)
#define MOTOR1_L_PWM 5     // PWM L (chân 5 - Timer0)
#define MOTOR1_R_PWM 6     // PWM R (chân 6 - Timer0)
#define MOTOR1_EN_L 7      // Enable L
#define MOTOR1_EN_R 8      // Enable R

// Motor 2 (Dùng Timer2 - Tránh chân ngắt)
#define MOTOR2_L_PWM 9     // PWM L (chân 9 - Timer1)
#define MOTOR2_R_PWM 10    // PWM R (chân 10 - Timer1)
#define MOTOR2_EN_L 11     // Enable L
#define MOTOR2_EN_R 12     // Enable R

// Encoder (Giữ nguyên chân ngắt 2,3)
Encoder enc1(2, 3);  // 
Encoder enc2(18, 19); //

// IMU (giả sử dùng MPU6050)
#define MPU6050_ADDR 0x68
int16_t angle = 0;

// Dữ liệu truyền
uint8_t ros[8] = {0x02, 0, 0, 0, 0, 0, 0, 0x03};
uint8_t rx_buffer[6];
int16_t en1 = 0, en2 = 0;

void read_encoders();
void read_imu();
void send_ros();
void receive_ros();
void setMotor1(int pwm, bool dir);
void setMotor2(int pwm, bool dir);
void stopAllMotors();
void printEncoderValues();


void setup() {
  Serial.begin(115200);// UART giao tiếp với ROS2
  Wire.begin(); // I2C giao tiếp với IMU
  // Cấu hình chân motor
  pinMode(MOTOR1_L_PWM, OUTPUT);
  pinMode(MOTOR1_R_PWM, OUTPUT);
  pinMode(MOTOR1_EN_L, OUTPUT);
  pinMode(MOTOR1_EN_R, OUTPUT);
  
  pinMode(MOTOR2_L_PWM, OUTPUT);
  pinMode(MOTOR2_R_PWM, OUTPUT);
  pinMode(MOTOR2_EN_L, OUTPUT);
  pinMode(MOTOR2_EN_R, OUTPUT);

  // Khởi tạo IMU
  Wire.beginTransmission(MPU6050_ADDR);
  Wire.write(0x6B); // Thanh ghi PWR_MGMT_1
  Wire.write(0); // Bật IMU
  Wire.endTransmission();

  stopAllMotors();
  Serial.println("Hệ thống đã sẵn sàng!");
}

void loop() {
  // Đọc và hiển thị encoder
  printEncoderValues();
  
  send_ros(); // Gửi dữ liệu encoder và IMU đến ROS2
  receive_ros(); // Nhận lệnh điều khiển từ ROS2
  delay(50); // Chu kỳ 50ms
}

// ========== HÀM ĐIỀU KHIỂN ========== //
void read_encoders() {
  en1 = enc1.read();
  en2 = enc2.read();
}

void read_imu() {
  Wire.beginTransmission(MPU6050_ADDR);
  Wire.write(0x3B); // Thanh ghi ACCEL_XOUT_H
  Wire.endTransmission(false);
  Wire.requestFrom(MPU6050_ADDR, 6, true);

  int16_t accel_x = Wire.read() << 8 | Wire.read();
  int16_t accel_y = Wire.read() << 8 | Wire.read();
  int16_t accel_z = Wire.read() << 8 | Wire.read();

  // Tính toán góc (giả sử chỉ dùng trục X)
  angle = atan2(accel_y, accel_z) * 180 / 3.14159;
}

void send_ros() {
  read_encoders();
  read_imu();

  ros[1] = angle >> 8;
  ros[2] = angle & 0xFF;
  ros[3] = en1 >> 8;
  ros[4] = en1 & 0xFF;
  ros[5] = en2 >> 8;
  ros[6] = en2 & 0xFF;

  Serial.write(ros, 8);
}

void receive_ros() {
  if (Serial.available() >= 6) {
    Serial.readBytes(rx_buffer, 6);

    uint8_t reset = rx_buffer[0];
    uint8_t dir1 = rx_buffer[1];
    uint8_t speed1 = rx_buffer[2];
    uint8_t dir2 = rx_buffer[3];
    uint8_t speed2 = rx_buffer[4];

    // Điều khiển động cơ 1
    setMotor1(speed1, dir1);

    // Điều khiển động cơ 2
    setMotor2(speed2, dir2);

    // Reset encoder nếu cần
    if (reset == 1) {
      enc1.write(0);
      enc2.write(0);
    }
  }
}

void setMotor1(int pwm, bool dir) {
  if(dir1) {
    analogWrite(MOTOR1_L_PWM, pwm);
    digitalWrite(MOTOR1_R_PWM, LOW);
    digitalWrite(MOTOR1_EN_L, HIGH);
    digitalWrite(MOTOR1_EN_R, LOW);
  } else {
    analogWrite(MOTOR1_R_PWM, pwm);
    digitalWrite(MOTOR1_L_PWM, LOW);
    digitalWrite(MOTOR1_EN_R, HIGH);
    digitalWrite(MOTOR1_EN_L, LOW);
  }
}

void setMotor2(int pwm, bool dir) {
  if(dir2) {
    analogWrite(MOTOR2_L_PWM, pwm);
    digitalWrite(MOTOR2_R_PWM, LOW);
    digitalWrite(MOTOR2_EN_L, HIGH);
    digitalWrite(MOTOR2_EN_R, LOW);
  } else {
    analogWrite(MOTOR2_R_PWM, pwm);
    digitalWrite(MOTOR2_L_PWM, LOW);
    digitalWrite(MOTOR2_EN_R, HIGH);
    digitalWrite(MOTOR2_EN_L, LOW);
  }
}

void stopAllMotors() {
  digitalWrite(MOTOR1_L_PWM, LOW);
  digitalWrite(MOTOR1_R_PWM, LOW);
  digitalWrite(MOTOR1_EN_L, LOW);
  digitalWrite(MOTOR1_EN_R, LOW);
  
  digitalWrite(MOTOR2_L_PWM, LOW);
  digitalWrite(MOTOR2_R_PWM, LOW);
  digitalWrite(MOTOR2_EN_L, LOW);
  digitalWrite(MOTOR2_EN_R, LOW);
}

void printEncoderValues() {
  static unsigned long lastPrint = 0;
  if(millis() - lastPrint > 100) {
    Serial.print("Enc1: ");
    Serial.print(enc1.read());
    Serial.print(" | Enc2: ");
    Serial.println(enc2.read());
    lastPrint = millis();
  }
}

